# Copy this file to .env and fill in real values.
# The server refuses to start if APP_PASSPHRASE is missing.

# Passphrase users must enter on the login page.
APP_PASSPHRASE=change-me

# Long random string used to sign the auth cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# Optional: port the server listens on (default 3000)
# PORT=3000
